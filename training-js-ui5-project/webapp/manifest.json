{
  "_version": "1.84.0",
  "sap.app": {
    "id": "trainingjsui5project",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.24.0",
      "toolsId": "efde776e-feef-4164-b47f-0985dec173a1"
    },
    "dataSources": {
      "mainService": {
        "uri": "/v2/northwind/northwind.svc/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.149.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "trainingjsui5project.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "trainingjsui5project.view",
        "async": true,
        "viewPath": "trainingjsui5project.view"
      },
      "routes": [
        {
          "name": "RouteProducts",
          "pattern": ":?query:",
          "target": ["TargetProducts"]
        },
        {
          "name": "RouteProductDetail",
          "pattern": "ProductDetail/{ProductID}",
          "target": ["TargetProductDetail"]
        },
        {
          "name": "RouteCategories",
          "pattern": "Categories",
          "target": ["TargetCategories"]
        },
        {
          "name": "RouteCustomers",
          "pattern": "Customers",
          "target": ["TargetCustomers"]
        },
        {
          "name": "RouteOrders",
          "pattern": "Orders",
          "target": ["TargetOrders"]
        },
        {
          "name": "RouteOrderDetail",
          "pattern": "OrderDetail/{OrderID}",
          "target": ["TargetOrderDetail"]
        }
      ],
      "targets": {
        "TargetProducts": {
          "id": "Products",
          "name": "Products"
        },
        "TargetProductDetail": {
          "id": "ProductDetail",
          "name": "ProductDetail"
        },
        "TargetCategories": {
          "id": "Categories",
          "name": "Categories"
        },
        "TargetCustomers": {
          "id": "Customers",
          "name": "Customers"
        },
        "TargetOrders": {
          "id": "Orders",
          "name": "Orders"
        },
        "TargetOrderDetail": {
          "id": "OrderDetail",
          "name": "OrderDetail"
        }
      }
    },
    "rootView": {
      "viewName": "trainingjsui5project.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
