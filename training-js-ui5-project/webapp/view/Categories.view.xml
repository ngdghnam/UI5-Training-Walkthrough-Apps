<mvc:View controllerName="trainingjsui5project.controller.Categories"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc">
    <Page id="categoriesPage" title="Categories" showNavButton="false">
        <content>
            <List id="categoryList" items="{/Categories}" class="sapUiResponsiveMargin" width="auto">
                <StandardListItem
                    title="{CategoryName}"
                    description="{Description}" />
            </List>
        </content>
    </Page>
</mvc:View>
