<mvc:View controllerName="trainingjsui5project.controller.Customers"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc">
    <Page id="customersPage" title="Customers" showNavButton="false">
        <content>
            <List id="customerList" items="{/Customers}" class="sapUiResponsiveMargin" width="auto">
                <ObjectListItem
                    title="{CompanyName}"
                    type="Active"
                    number="{CustomerID}">
                    <attributes>
                        <ObjectAttribute text="{ContactName} - {ContactTitle}" />
                        <ObjectAttribute text="{City}, {Country}" />
                    </attributes>
                </ObjectListItem>
            </List>
        </content>
    </Page>
</mvc:View>
