<mvc:View controllerName="trainingjsui5project.controller.Orders"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc">
    <Page id="ordersPage" title="Orders" showNavButton="false">
        <content>
            <Table id="ordersTable" items="{
                path: '/Orders',
                parameters: {
                    expand: 'Customer'
                }
            }" class="sapUiResponsiveMargin" width="auto">
                <columns>
                    <Column>
                        <Text text="Order ID" />
                    </Column>
                    <Column>
                        <Text text="Customer" />
                    </Column>
                    <Column>
                        <Text text="Order Date" />
                    </Column>
                    <Column>
                        <Text text="Ship Country" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press=".onNavToOrderDetail">
                        <cells>
                            <ObjectIdentifier title="{OrderID}" />
                            <Text text="{Customer/CompanyName}" />
                            <Text text="{
                                path: 'OrderDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: {style: 'medium'}
                            }" />
                            <Text text="{ShipCountry}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
