<mvc:View controllerName="trainingjsui5project.controller.Products"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:svm="sap.ui.comp.smartvariants"
    xmlns:v="sap.ui.comp.variants"
    xmlns:f="sap.f"
    xmlns="sap.m">
    <f:DynamicPage id="page" headerExpanded="true">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>title}" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <f:content>
                    <OverflowToolbar>
                        <v:VariantManagement id="variant" standardItemText="Standard" />
                    </OverflowToolbar>
        <fb:FilterBar id="filterBar" search=".onSearch" clear=".onClear" useToolbar="true" showClearOnFB="true" showFilterConfiguration="true">

            <fb:filterGroupItems>
                <fb:FilterGroupItem groupName="G1" name="ProductID" label="Product ID" visibleInFilterBar="true">
                    <fb:control>
                        <Input id="filterProductID" />
                    </fb:control>
                </fb:FilterGroupItem>
                <fb:FilterGroupItem groupName="G1" name="ProductName" label="Product Name" visibleInFilterBar="true">
                    <fb:control>
                        <Input id="filterProductName" />
                    </fb:control>
                </fb:FilterGroupItem>
                <fb:FilterGroupItem groupName="G1" name="QuantityPerUnit" label="Quantity Per Unit" visibleInFilterBar="true">
                    <fb:control>
                        <Input id="filterQuantityPerUnit" />
                    </fb:control>
                </fb:FilterGroupItem>
                <fb:FilterGroupItem groupName="G1" name="UnitPrice" label="Unit Price" visibleInFilterBar="true">
                    <fb:control>
                        <Input id="filterUnitPrice" type="Number" />
                    </fb:control>
                </fb:FilterGroupItem>
                <fb:FilterGroupItem groupName="G1" name="UnitsInStock" label="Units in Stock" visibleInFilterBar="true">
                    <fb:control>
                        <Input id="filterUnitsInStock" type="Number" />
                    </fb:control>
                </fb:FilterGroupItem>
            </fb:filterGroupItems>
        </fb:FilterBar>
                </f:content>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <Table id="ProductTable" growing="true" sticky="ColumnHeaders,HeaderToolbar" width="auto"
            items="{path: '/Products',sorter: { path: 'ProductID'}}"
            updateFinished=".onUpdateFinished"
            class="sapUiResponsiveMargin">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title id="tableHeader" text="All Items" titleStyle="H6" />
                        <ToolbarSpacer />
                        <Button tooltip="Export to Excel" icon="sap-icon://excel-attachment" press="onExport" type="Transparent" />
                        <Button tooltip="Back to Top" icon="sap-icon://arrow-top" press=".onBackToTop" type="Transparent" />
                    </OverflowToolbar>
                </headerToolbar>

            <!-- Headers -->
            <columns>
                <Column hAlign="Begin" vAlign="Middle" minScreenWidth="Phone" demandPopin="true" width="6rem">
                    <Label text="Product ID" design="Bold" />
                </Column>
                <Column hAlign="Begin" vAlign="Middle" minScreenWidth="Phone" demandPopin="true">
                    <Label text="Name" design="Bold" />
                </Column>
                <Column hAlign="Begin" vAlign="Middle" minScreenWidth="Phone" demandPopin="true" width="12rem">
                    <Label text="Quantity Per Unit" design="Bold" />
                </Column>
                <Column hAlign="End" vAlign="Middle" minScreenWidth="Phone" demandPopin="true" width="7rem">
                    <Label text="Unit Price" design="Bold" />
                </Column>
                <Column hAlign="End" vAlign="Middle" minScreenWidth="Phone" demandPopin="true" width="8rem">
                    <Label text="Units in Stock" design="Bold" />
                </Column>
                <Column hAlign="End" vAlign="Middle" minScreenWidth="Phone" demandPopin="true" width="8rem">
                    <Label text="Units on Order" design="Bold" />
                </Column>
                <Column hAlign="End" vAlign="Middle" minScreenWidth="Phone" demandPopin="true" width="8rem">
                    <Label text="Reorder Level" design="Bold" />
                </Column>
            </columns>

            <!-- Items -->
            <items>
                <ColumnListItem type="Navigation" press=".onNavToDetailPress">
                    <cells>
                        <Label text="{path: 'ProductID', type: 'sap.ui.model.odata.type.String'}"
                            design="Bold" />
                        <Label text="{path: 'ProductName', type: 'sap.ui.model.odata.type.String'}"
                            design="Bold" />
                        <Text text="{path: 'QuantityPerUnit'}"
                            wrapping="false" maxLines="1" />
                        <ObjectNumber
                            number="{path: 'UnitPrice'}"
                            unit="$"
                            emphasized="false"
                            state="{
                                path: 'UnitPrice',
                                formatter: '.formatter.priceState'
                            }" />
                        <ObjectStatus
                            text="{path: 'UnitsInStock'}"
                            state="{
                                path: 'UnitsInStock',
                                formatter: '.formatter.stockState'
                            }" />
                        <ObjectStatus
                            text="{path: 'UnitsOnOrder'}"
                            state="{
                                path: 'UnitsOnOrder',
                                formatter: '.formatter.orderState'
                            }" />
                        <Text text="{path: 'ReorderLevel'}"
                            wrapping="false" maxLines="1" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>